{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ugit",
  "version": "0.1.0",
  "identifier": "com.surajnegi.ugit",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ugit",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/ugit"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZGM0FEODY4M0NDNjc0MzUKUldRMWRNWThhTmc2LzFlZzM3Ly9DUFAvU251NGtjQ1lxZFZhVzY4RGRIMlp5T0JZcE4zK1A5R3cK",
      "endpoints": ["https://github.com/ssnxd/ugit/releases/latest/download/latest.json"]
    }
  }
}
