# Copy to `.env` (gitignored) and fill in. Loaded by scripts/build-local.sh to
# sign the updater artifacts during `tauri build`.
#
# TAURI_SIGNING_PRIVATE_KEY may be the path to your key file OR its contents.
TAURI_SIGNING_PRIVATE_KEY="$HOME/.tauri/ugit.key"
TAURI_SIGNING_PRIVATE_KEY_PASSWORD="your-passphrase"
